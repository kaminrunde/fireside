{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "incremental": false,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["es2020", "dom"],
    "module": "ES2020",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "outDir": "lib",
    "rootDir": "./src",
    "skipLibCheck": true,
    "target": "ES2020"
  },
  "include": ["src/**/*"]
}